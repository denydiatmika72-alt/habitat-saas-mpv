// ============================================================
// HABITAT - Music Event SaaS
// Prisma Schema File
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  events    Event[]

  @@map("users")
}

model Event {
  id                 String   @id @default(uuid())
  title              String
  location           String
  event_date         DateTime
  venue_capacity     Int
  target_profit      Decimal  @db.Decimal(15, 2)
  target_sponsorship Decimal  @db.Decimal(15, 2)
  status             String   @default("DRAFT")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt      @map("updated_at")

  promotor_id        String
  promotor           User     @relation(fields: [promotor_id], references: [id])
  budget             Budget?

  @@map("events")
}

model Budget {
  id                        String           @id @default(uuid())
  eventId                   String           @unique @map("event_id")
  event                     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  totalEstimatedCost        Decimal          @default(0) @db.Decimal(15, 2)
  contingencyFundPercentage Decimal          @default(20.00) @db.Decimal(5, 2)
  contingencyFundAmount     Decimal          @default(0) @db.Decimal(15, 2)
  createdAt                 DateTime         @default(now()) @map("created_at")
  categories                BudgetCategory[]

  @@map("budgets")
}

model BudgetCategory {
  id              String       @id @default(uuid())
  budgetId        String       @map("budget_id")
  budget          Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name            String
  allocatedBudget Decimal      @default(0) @db.Decimal(15, 2)
  items           BudgetItem[]

  @@map("budget_categories")
}

model BudgetItem {
  id            String         @id @default(uuid())
  categoryId    String         @map("category_id")
  category      BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name          String
  qty           Int            @default(1)
  hargaSatuan   Decimal        @default(0) @db.Decimal(15, 2)
  estimatedCost Decimal        @default(0) @db.Decimal(15, 2)
  actualCost    Decimal        @default(0) @db.Decimal(15, 2)

  @@map("budget_items")
}

model SponsorDeal {
  id          String               @id @default(uuid())
  eventId     String?              @map("event_id")
  sponsorName String               @map("sponsor_name")
  contactName String               @default("") @map("contact_name")
  email       String
  tier        String
  codeUsed    String               @map("code_used")
  totalValue  Decimal              @default(0) @db.Decimal(15, 2) @map("total_value")
  status      String               @default("Negosiasi")
  createdAt   DateTime             @default(now()) @map("created_at")
  account     ClientAccount?
  deliverables SponsorDeliverable[]

  @@map("sponsor_deals")
}

model InviteCode {
  id        String    @id @default(uuid())
  code      String    @unique
  eventId   String?   @map("event_id")
  createdBy String    @map("created_by")
  usedBy    String?   @map("used_by")
  usedAt    DateTime? @map("used_at")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("invite_codes")
}

model SponsorDeliverable {
  id            String      @id @default(uuid())
  dealId        String      @map("deal_id")
  deal          SponsorDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title         String
  category      String
  status        String      @default("Planning")
  proofImageUrl String?     @map("proof_image_url")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("sponsor_deliverables")
}

model SponsorBenefit {
  id          String                  @id @default(uuid())
  name        String
  category    String
  description String                  @default("")
  price       Decimal                 @db.Decimal(15, 2)
  createdAt   DateTime                @default(now()) @map("created_at")
  packages    SponsorPackageBenefit[]

  @@map("sponsor_benefits")
}

model SponsorPackage {
  id          String                  @id @default(uuid())
  eventId     String?                 @map("event_id")
  name        String
  price       Decimal                 @db.Decimal(15, 2)
  slots       Int                     @default(1)
  description String                  @default("")
  createdAt   DateTime                @default(now()) @map("created_at")
  benefits    SponsorPackageBenefit[]

  @@map("sponsor_packages")
}

model SponsorPackageBenefit {
  packageId  String         @map("package_id")
  benefitId  String         @map("benefit_id")
  package    SponsorPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  benefit    SponsorBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)

  @@id([packageId, benefitId])
  @@map("sponsor_package_benefits")
}

model SponsorThreshold {
  id        String   @id @default(uuid())
  tierName  String   @unique @map("tier_name")
  minPrice  Decimal  @db.Decimal(15, 2) @map("min_price")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sponsor_thresholds")
}

model ClientAccount {
  id          String      @id @default(uuid())
  dealId      String      @unique @map("deal_id")
  deal        SponsorDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sponsorName String      @map("sponsor_name")
  username    String      @unique
  password    String
  tier        String      @default("")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("client_accounts")
}
