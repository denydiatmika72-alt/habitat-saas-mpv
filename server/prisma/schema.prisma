// ============================================================
// nexEvent - Music Event SaaS
// Prisma Schema File
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  status    String   @default("pending")
  plan      String   @default("starter")
  role      String   @default("promotor")
  isAdmin   Boolean  @default(false)

  proEventId   String?
  proExpiresAt DateTime?
  proStartedAt DateTime?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  events            Event[]
  expenses          Expense[]
  eventCrew         EventCrew[]
  pettyCashAccounts PettyCashAccount[]
  otherIncomes      OtherIncome[]
  proTransactions   ProTransaction[]

  @@map("users")
}

model ProTransaction {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  eventId       String?   @map("event_id")
  type          String    // "activation" | "extension"
  amount        Int
  orderId       String    @unique @map("order_id")
  status        String    @default("pending") // "pending" | "paid" | "failed" | "expired"
  midtransToken String?   @map("midtrans_token")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pro_transactions")
}

model Event {
  id                 String   @id @default(uuid())
  title              String
  location           String
  event_date         DateTime
  venue_capacity     Int
  target_profit      Decimal  @db.Decimal(15, 2)
  target_sponsorship Decimal  @db.Decimal(15, 2)
  status             String   @default("DRAFT")
  is_published       Boolean  @default(false)

  slug              String?   @unique
  saleStartAt       DateTime? @map("sale_start_at")
  saleEndAt         DateTime? @map("sale_end_at")
  storefrontStatus  String    @default("draft") @map("storefront_status")
  storefrontNote    String?   @map("storefront_note")

  bannerUrl          String?  @map("banner_url")
  logoUrl            String?  @map("logo_url")
  taxEnabled         Boolean  @default(false) @map("tax_enabled")
  feeBearer          String?  @map("fee_bearer")
  platformFeePercent Float?   @map("platform_fee_percent")

  description        String?
  facilities         Json?
  termsConditions    String?  @map("terms_conditions")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt      @map("updated_at")

  promotor_id        String
  promotor           User              @relation(fields: [promotor_id], references: [id])
  budget             Budget?
  purchaseOrders     PurchaseOrder[]
  expenses           Expense[]
  crew               EventCrew[]
  pettyCashAccounts  PettyCashAccount[]
  otherIncomes       OtherIncome[]
  ticketTypes        TicketType[]
  ticketOrders       TicketOrder[]
  merchItems         MerchItem[]

  @@map("events")
}

model TicketType {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  name        String
  description String?
  price       Int
  quota       Int
  sold        Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems  TicketOrderItem[]

  @@map("ticket_types")
}

model TicketOrder {
  id              String    @id @default(uuid())
  eventId         String    @map("event_id")
  orderId         String    @unique @map("order_id")
  buyerName       String    @map("buyer_name")
  buyerEmail      String    @map("buyer_email")
  buyerPhone      String    @map("buyer_phone")
  buyerNik        String    @map("buyer_nik")
  totalAmount     Int       @map("total_amount")
  feeAmount       Int       @default(0) @map("fee_amount")
  feeBearer       String    @default("promotor") @map("fee_bearer")
  taxAmount       Int       @default(0) @map("tax_amount")
  orderType       String    @default("ticket") @map("order_type") // "ticket" | "merch" | "bundling"
  status          String    @default("pending")
  midtransToken   String?   @map("midtrans_token")
  paidAt          DateTime? @map("paid_at")
  expiredAt       DateTime  @map("expired_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items           TicketOrderItem[]
  merchItems      MerchOrderItem[]

  @@map("ticket_orders")
}

model MerchItem {
  id          String           @id @default(uuid())
  eventId     String           @map("event_id")
  name        String
  description String?
  price       Int
  imageUrl    String?          @map("image_url")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt      @map("updated_at")

  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  variants    MerchVariant[]
  orderItems  MerchOrderItem[]

  @@map("merch_items")
}

model MerchVariant {
  id          String           @id @default(uuid())
  merchItemId String           @map("merch_item_id")
  size        String           // "S" | "M" | "L" | "XL" | "XXL" | "FREE SIZE" | "ONE SIZE"
  stock       Int              @default(0)
  sold        Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at")

  item        MerchItem        @relation(fields: [merchItemId], references: [id], onDelete: Cascade)
  orderItems  MerchOrderItem[]

  @@unique([merchItemId, size])
  @@map("merch_variants")
}

model MerchOrderItem {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  merchItemId String       @map("merch_item_id")
  variantId   String       @map("variant_id")
  quantity    Int
  price       Int
  createdAt   DateTime     @default(now()) @map("created_at")

  order       TicketOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item        MerchItem    @relation(fields: [merchItemId], references: [id])
  variant     MerchVariant @relation(fields: [variantId], references: [id])

  @@map("merch_order_items")
}

model TicketOrderItem {
  id           String      @id @default(uuid())
  orderId      String      @map("order_id")
  ticketTypeId String      @map("ticket_type_id")
  quantity     Int
  price        Int
  createdAt    DateTime    @default(now()) @map("created_at")

  order        TicketOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType  @relation(fields: [ticketTypeId], references: [id])
  tickets      Ticket[]

  @@map("ticket_order_items")
}

model Ticket {
  id           String          @id @default(uuid())
  orderItemId  String          @map("order_item_id")
  ticketCode   String          @unique @map("ticket_code")
  attendeeName String?         @map("attendee_name")
  isUsed       Boolean         @default(false) @map("is_used")
  usedAt       DateTime?       @map("used_at")
  createdAt    DateTime        @default(now()) @map("created_at")

  orderItem    TicketOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("tickets")
}

model Expense {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  userId      String   @map("user_id")
  description String
  amount      Float
  category    String
  receiptUrl  String?  @map("receipt_url")
  date        DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Budget {
  id                        String           @id @default(uuid())
  eventId                   String           @unique @map("event_id")
  event                     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  totalEstimatedCost        Decimal          @default(0) @db.Decimal(15, 2)
  contingencyFundPercentage Decimal          @default(20.00) @db.Decimal(5, 2)
  contingencyFundAmount     Decimal          @default(0) @db.Decimal(15, 2)
  createdAt                 DateTime         @default(now()) @map("created_at")
  categories                BudgetCategory[]

  @@map("budgets")
}

model BudgetCategory {
  id              String       @id @default(uuid())
  budgetId        String       @map("budget_id")
  budget          Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name            String
  allocatedBudget Decimal      @default(0) @db.Decimal(15, 2)
  items           BudgetItem[]

  @@map("budget_categories")
}

model BudgetItem {
  id            String         @id @default(uuid())
  categoryId    String         @map("category_id")
  category      BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name          String
  qty           Int            @default(1)
  hargaSatuan   Decimal        @default(0) @db.Decimal(15, 2)
  estimatedCost Decimal        @default(0) @db.Decimal(15, 2)
  actualCost    Decimal        @default(0) @db.Decimal(15, 2)

  @@map("budget_items")
}

model SponsorDeal {
  id           String               @id @default(uuid())
  eventId      String?              @map("event_id")
  packageId    String?              @map("package_id")
  sponsorName  String               @map("sponsor_name")
  contactName  String               @default("") @map("contact_name")
  email        String
  tier         String
  codeUsed     String               @map("code_used")
  totalValue   Decimal              @default(0) @db.Decimal(15, 2) @map("total_value")
  status       String               @default("Negosiasi")
  createdAt    DateTime             @default(now()) @map("created_at")
  account      ClientAccount?
  deliverables SponsorDeliverable[]
  dealBenefits SponsorDealBenefit[]
  invoices     SponsorInvoice[]

  @@map("sponsor_deals")
}

model InviteCode {
  id        String    @id @default(uuid())
  code      String    @unique
  eventId   String?   @map("event_id")
  createdBy String    @map("created_by")
  usedBy    String?   @map("used_by")
  usedAt    DateTime? @map("used_at")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("invite_codes")
}

model SponsorDeliverable {
  id            String      @id @default(uuid())
  dealId        String      @map("deal_id")
  deal          SponsorDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title         String
  category      String
  status        String      @default("Planning")
  proofImageUrl String?     @map("proof_image_url")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("sponsor_deliverables")
}

model SponsorBenefit {
  id           String                  @id @default(uuid())
  name         String
  category     String
  description  String                  @default("")
  price        Decimal                 @db.Decimal(15, 2)
  maxQty       Int                     @default(1) @map("max_qty")
  usedQty      Int                     @default(0) @map("used_qty")
  heldQty      Int                     @default(0) @map("held_qty")
  createdAt    DateTime                @default(now()) @map("created_at")
  packages     SponsorPackageBenefit[]
  dealBenefits SponsorDealBenefit[]

  @@map("sponsor_benefits")
}

model SponsorPackage {
  id          String                  @id @default(uuid())
  eventId     String?                 @map("event_id")
  name        String
  price       Decimal                 @db.Decimal(15, 2)
  slots       Int                     @default(1)
  description String                  @default("")
  createdAt   DateTime                @default(now()) @map("created_at")
  benefits    SponsorPackageBenefit[]

  @@map("sponsor_packages")
}

model SponsorPackageBenefit {
  packageId  String         @map("package_id")
  benefitId  String         @map("benefit_id")
  qty        Int            @default(1)
  package    SponsorPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  benefit    SponsorBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)

  @@id([packageId, benefitId])
  @@map("sponsor_package_benefits")
}

model SponsorDealBenefit {
  id         String         @id @default(cuid())
  dealId     String         @map("deal_id")
  benefitId  String         @map("benefit_id")
  qty        Int
  unitPrice  Decimal        @db.Decimal(15, 2) @map("unit_price")
  totalPrice Decimal        @db.Decimal(15, 2) @map("total_price")
  deal       SponsorDeal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  benefit    SponsorBenefit @relation(fields: [benefitId], references: [id])
  createdAt  DateTime       @default(now()) @map("created_at")

  @@map("sponsor_deal_benefits")
}

model SponsorThreshold {
  id        String   @id @default(uuid())
  tierName  String   @unique @map("tier_name")
  minPrice  Decimal  @db.Decimal(15, 2) @map("min_price")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sponsor_thresholds")
}

model ClientAccount {
  id          String      @id @default(uuid())
  dealId      String      @unique @map("deal_id")
  deal        SponsorDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sponsorName String      @map("sponsor_name")
  username    String      @unique
  password    String
  tier        String      @default("")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("client_accounts")
}

model SponsorInvoice {
  id              String      @id @default(cuid())
  invoiceNumber   String      @unique @map("invoice_number")
  dealId          String      @map("deal_id")
  deal            SponsorDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sponsorName     String      @map("sponsor_name")
  sponsorEmail    String      @map("sponsor_email")
  contactName     String      @map("contact_name")
  promotorName    String      @map("promotor_name")
  promotorLogo    String?     @map("promotor_logo")
  bankName        String      @map("bank_name")
  bankAccount     String      @map("bank_account")
  accountHolder   String      @map("account_holder")
  items           Json
  grandTotal      Decimal     @db.Decimal(15, 2) @map("grand_total")
  itemsSubtotal   Decimal     @default(0) @db.Decimal(15, 2) @map("items_subtotal")
  discount        Decimal     @default(0) @db.Decimal(15, 2)
  invoiceSource   String      @default("alacarte") @map("invoice_source")
  status          String      @default("Belum Dibayar")
  invoiceType     String      @default("sponsorship") @map("invoice_type")
  bonusItems      Json?       @map("bonus_items")
  currentTier     String      @map("current_tier")
  nextTier        String?     @map("next_tier")
  amountToUpgrade Decimal?    @db.Decimal(15, 2) @map("amount_to_upgrade")
  pdfUrl          String?     @map("pdf_url")
  paidAt          DateTime?   @map("paid_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("sponsor_invoices")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  eventId     String              @map("event_id")
  vendorId    String?             @map("vendor_id")
  title       String
  status      String              @default("draft")
  totalAmount Float               @default(0) @map("total_amount")
  notes       String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  event       Event               @relation(fields: [eventId], references: [id])
  items       PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String        @map("purchase_order_id")
  name            String
  qty             Float
  unitPrice       Float         @map("unit_price")
  totalPrice      Float         @map("total_price")
  sourceRabItemId String?       @map("source_rab_item_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

model PromoterSettings {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  logoUrl       String?  @map("logo_url")
  companyName   String?  @map("company_name")
  bankName      String?  @map("bank_name")
  bankAccount   String?  @map("bank_account")
  accountHolder String?  @map("account_holder")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("promoter_settings")
}

model EventCrew {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  division  String
  createdAt DateTime @default(now()) @map("created_at")

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_crew")
}

model PettyCashAccount {
  id           String                 @id @default(uuid())
  eventId      String                 @map("event_id")
  userId       String                 @map("user_id")
  division     String
  createdAt    DateTime               @default(now()) @map("created_at")

  event        Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions PettyCashTransaction[]

  @@unique([eventId, userId])
  @@map("petty_cash_accounts")
}

model OtherIncome {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  userId      String   @map("user_id")
  description String
  amount      Float
  date        DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("other_incomes")
}

model PettyCashTransaction {
  id          String           @id @default(uuid())
  accountId   String           @map("account_id")
  type        String           // "topup" | "expense" | "return"
  amount      Float
  description String
  createdAt   DateTime         @default(now()) @map("created_at")
  createdBy   String           @map("created_by")

  account     PettyCashAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("petty_cash_transactions")
}
